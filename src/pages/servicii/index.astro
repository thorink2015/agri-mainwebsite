---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import ServiceCard from '../../components/ServiceCard.astro';

const VIE_IMG = "https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=900&q=70";
const LIVEZI_IMG = "https://images.unsplash.com/photo-1476900543704-4312b78632f8?auto=format&fit=crop&w=900&q=70";
const CEREALE_IMG = "https://images.unsplash.com/photo-1625246333195-78d9c38ad449?auto=format&fit=crop&w=900&q=70";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Servicii de pulverizare cu drona",
  "provider": { "@id": "https://hectar.ro/#organization" },
  "areaServed": ["Romania", "Moldova"],
  "description": "Tratamente cu drona pentru vii, livezi, cereale și rapiță în România și Moldova."
};
---

<BaseLayout
  title="Servicii de pulverizare cu drona · Hectar"
  description="Tratamente cu drona pentru vii, livezi, cereale și rapiță în România și Moldova. Servicii profesionale, prețuri clare, programare rapidă."
  canonical="/servicii"
  schema={schema}
>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">Ce facem</span>
      <h1>Servicii de tratament cu drona</h1>
      <p class="lead">Lucrăm pe orice cultură care poate fi pulverizată. Dacă ai ceva aparte, sună-ne — găsim o soluție.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-3">
        <ServiceCard
          title="Tratamente pentru vii și podgorii"
          description="Vii de masă și de vin, pe pantă sau în câmp deschis. Mana, făinarea, moliile viei, tratamente cu sulf și cupru. Intrăm unde tractorul nu mai are loc."
          href="/servicii/vie"
          linkLabel="Detalii și preț"
          imgSrc={VIE_IMG}
          imgAlt="Podgorie tratată cu drona"
          price="18 €"
          tag="Vie"
        />
        <ServiceCard
          title="Tratamente pentru livezi"
          description="Meri, peri, pruni, cireși, caiși, nuci. Tratamente de iarnă, de înflorire, pe fruct. Fără scări, fără rupt crengi, fără tractor printre pomi."
          href="/servicii/livezi"
          linkLabel="Detalii și preț"
          imgSrc={LIVEZI_IMG}
          imgAlt="Livadă tratată cu drona"
          price="15 €"
          tag="Livadă"
        />
        <ServiceCard
          title="Cereale, rapiță, porumb, floarea-soarelui"
          description="Fungicide, insecticide, erbicide, biostimulatori, îngrășăminte foliare. Ideal când solul e umed sau cultura e prea înaltă pentru tractor."
          href="/servicii/cereale"
          linkLabel="Detalii și preț"
          imgSrc={CEREALE_IMG}
          imgAlt="Câmp de cereale tratat cu drona"
          price="15 €"
          tag="Cereale"
        />
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2" style="gap: var(--space-xl); align-items: start;">
        <div>
          <span class="eyebrow">Ce putem pulveriza</span>
          <h2>Tipuri de soluții</h2>
          <ul class="solutions-list">
            <li>Fungicide (împotriva bolilor)</li>
            <li>Insecticide (împotriva dăunătorilor)</li>
            <li>Erbicide (pentru buruieni, suprafețe mari)</li>
            <li>Biostimulatori și îngrășăminte foliare</li>
            <li>Tratamente biologice și ecologice</li>
            <li>Sulf și cupru pentru vie</li>
          </ul>
          <p class="mt-md text-muted text-small">Dacă ai deja soluția cumpărată, o folosim pe a ta. Dacă nu, te ajutăm să o găsești la un preț bun de la un furnizor de încredere.</p>
        </div>
        <div>
          <span class="eyebrow">Limite clare</span>
          <h2>Ce nu facem</h2>
          <div class="limit-box">
            <p>Nu facem desecare aeriană cu glifosat pe suprafețe sub 10 hectare. Nu lucrăm pe vânt peste 4 m/s. Nu zburăm lângă locuințe mai aproape de 50 de metri. Siguranța e pe primul loc.</p>
            <p class="mt-sm">Spunem asta de la început pentru că preferi să știi dinainte.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-bg-dark);
    padding-block: var(--space-xl) var(--space-2xl);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .page-hero .eyebrow { color: var(--color-accent-light); }
  .page-hero .eyebrow::before { background: var(--color-accent-light); }

  .page-hero h1 {
    font-size: var(--fs-h1);
    color: var(--color-text-inverse);
    margin-bottom: var(--space-md);
  }

  .page-hero .lead {
    color: rgba(247,243,234,0.65);
    max-width: 520px;
    margin: 0;
  }

  .solutions-list {
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-left: 0;
    list-style: none;
  }

  .solutions-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--fs-small);
    font-weight: 500;
    padding: 10px 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .solutions-list li::before {
    content: "";
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  .limit-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-top: var(--space-md);
  }

  .limit-box p {
    color: var(--color-text-muted);
    font-size: var(--fs-small);
    line-height: var(--lh-relaxed);
    margin: 0;
  }
</style>
