---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';

const IMG_HERO = "https://images.unsplash.com/photo-1476900543704-4312b78632f8?auto=format&fit=crop&w=1400&q=75";
const IMG_2 = "https://images.unsplash.com/photo-1560493676-04071c5f467b?auto=format&fit=crop&w=900&q=70";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Pulverizare cu drona pentru livezi",
  "provider": { "@id": "https://hectar.ro/#organization" },
  "areaServed": ["Romania", "Moldova"],
  "description": "Pulverizare aeriană pentru livezi de meri, peri, pruni, cireși, caiși și nuci. Tratamente rapide, fără scări, fără stricat crengi. De la 15 €/ha.",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "EUR", "price": "15",
    "priceSpecification": { "@type": "UnitPriceSpecification", "price": "15", "priceCurrency": "EUR", "unitText": "HECTARE" }
  }
};

const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Acasă", "item": "https://hectar.ro/" },
    { "@type": "ListItem", "position": 2, "name": "Servicii", "item": "https://hectar.ro/servicii" },
    { "@type": "ListItem", "position": 3, "name": "Tratamente livezi", "item": "https://hectar.ro/servicii/livezi" }
  ]
};
---

<BaseLayout
  title="Tratamente cu drona pentru livezi · Meri, pruni, cireși · Hectar"
  description="Pulverizare aeriană pentru livezi de meri, peri, pruni, cireși, caiși și nuci. Fără scări, fără crengi rupte, fără tractor printre pomi. De la 15 €/ha."
  canonical="/servicii/livezi"
  schema={[schema, breadcrumb]}
>
  <!-- Hero cu imagine -->
  <div class="service-hero" style={`background-image: url('${IMG_HERO}')`}>
    <div class="service-hero-overlay"></div>
    <div class="container service-hero-content">
      <nav aria-label="Breadcrumb" class="breadcrumb breadcrumb--light">
        <a href="/">Acasă</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <a href="/servicii">Servicii</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <span aria-current="page">Tratamente livezi</span>
      </nav>
      <span class="eyebrow eyebrow--light">Pomi fructiferi</span>
      <h1>Tratamente cu drona pentru livezi</h1>
      <p class="service-hero-lead">Livada nu iartă un tratament ratat. Rapăn, monilioze, insecte — toate vin repede și pleacă greu. Drona acoperă uniform, fără să rupă crengi, fără să-ți calce solul.</p>
      <div class="flex-wrap mt-lg">
        <a href="/contact" class="btn-primary btn-lg">Cere ofertă gratuită</a>
        <a href="tel:+40700000000" class="btn-ghost btn-lg">Sună acum</a>
      </div>
    </div>
  </div>

  <div class="container section">
    <div class="page-grid">
      <div class="prose">
        <h2>Ce tratăm la livadă</h2>
        <div class="treatment-list">
          <div class="treatment-item">
            <div class="treatment-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </div>
            <div>
              <h3>Rapăn și rugini</h3>
              <p>Cel mai frecvent dușman al merilor și perilor. Tratamente preventive cu fungicide pe bază de captan, ditiocarbamat sau triazoli. Timing la umectare — înainte de ploaie sau imediat după.</p>
            </div>
          </div>
          <div class="treatment-item">
            <div class="treatment-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12m0 0C12 6 7 2 2 2c0 5 4 10 10 10zm0 0c0-6 5-10 10-10-5 0-10 5-10 10z"/></svg>
            </div>
            <div>
              <h3>Monilioza (putregaiul brun)</h3>
              <p>Atacă la înflorit și pe fruct. Critică la cireși, pruni și caiși. Tratament obligatoriu la înflorit și la pârgă — altfel pierzi jumătate din recoltă.</p>
            </div>
          </div>
          <div class="treatment-item">
            <div class="treatment-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <div>
              <h3>Insecte și viermi ai fructelor</h3>
              <p>Viermele merelor, păduchele San Jose, afide, acarieni. Insecticide de contact sau sistemice, aplicate la momentul optim din ciclul de viață al dăunătorului.</p>
            </div>
          </div>
          <div class="treatment-item">
            <div class="treatment-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 10 10c0 5.52-4.48 10-10 10S2 17.52 2 12 6.48 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <h3>Tratamente de iarnă</h3>
              <p>Ulei horticultural + cupru înainte de dezmugurit. Curăță ouăle de iarnă ale acarienilor și păduchilor de scoarță, reduci presiunea bolilor pentru tot sezonul.</p>
            </div>
          </div>
        </div>

        <h2>De ce drona lucrează mai bine decât tractorul în livadă</h2>

        <div class="img-frame aspect-16-9 mt-md mb-lg">
          <img src={IMG_2} alt="Livadă de pomi fructiferi tratată cu drona" loading="lazy" decoding="async" onerror="this.style.display='none'" />
        </div>

        <div class="benefit-blocks">
          <div class="benefit-block">
            <h3>Fără crengi rupte</h3>
            <p>Tractorul cu turbina intră cu forța. Drona trece pe deasupra coroanei la 2–3 metri, distribuind uniform, fără contact fizic cu pomii.</p>
          </div>
          <div class="benefit-block">
            <h3>Sub coroana pomilor</h3>
            <p>Rotoarele dronei creează un curent descendent care deschide frunzele și trimite picăturile inclusiv în interiorul coroanei — unde convențional nu ajungi.</p>
          </div>
          <div class="benefit-block">
            <h3>La înflorit — fără albine</h3>
            <p>Zburăm seara sau dimineața devreme, când albinele sunt în stup. La înflorit, fiecare zi contează — faci tratamentul fără să riști polenizorii.</p>
          </div>
          <div class="benefit-block">
            <h3>Pe teren umed sau accidentat</h3>
            <p>Primăvara timpurie, când solul e ud și tractorul ar face șanțuri adânci — drona operează la fel, indiferent de starea terenului.</p>
          </div>
        </div>

        <div class="calendar-box mt-xl">
          <h2>Calendar orientativ pentru livezi</h2>
          <div class="calendar-grid">
            <div class="cal-item"><span class="cal-period">Ianuarie – Februrie</span><span class="cal-desc">Tratament de iarnă — ulei horticultural + cupru</span></div>
            <div class="cal-item"><span class="cal-period">Martie – Aprilie</span><span class="cal-desc">Dezmugurit, umflarea mugurilor, buton roz</span></div>
            <div class="cal-item"><span class="cal-period">Mai</span><span class="cal-desc">La căderea petalelor — monilioze, rapăn</span></div>
            <div class="cal-item"><span class="cal-period">Iunie</span><span class="cal-desc">Tratamente pe fruct — rapăn, insecte</span></div>
            <div class="cal-item"><span class="cal-period">Iulie – August</span><span class="cal-desc">Tratamente finale, pârgă cireșe/prune</span></div>
          </div>
        </div>

        <div class="price-section mt-xl">
          <h2>Preț orientativ pentru livezi</h2>
          <div class="price-table-simple">
            <div class="price-row">
              <span>1 – 10 hectare</span>
              <span class="price-val">22 €/ha</span>
            </div>
            <div class="price-row">
              <span>10 – 50 hectare</span>
              <span class="price-val">18 €/ha</span>
            </div>
            <div class="price-row">
              <span>Peste 50 hectare</span>
              <span class="price-val">15 €/ha</span>
            </div>
            <div class="price-row price-row--note">
              <span>Tratament de noapte</span>
              <span class="price-val">+ 3 €/ha</span>
            </div>
          </div>
          <p class="mt-sm text-small text-muted">Prețul final depinde de suprafață, distanță și tipul de tratament. Dacă ai soluția ta, folosim soluția ta — nu te forțăm să cumperi altceva.</p>
        </div>
      </div>

      <aside class="page-sidebar">
        <div class="sidebar-cta">
          <h3>Cere ofertă pentru livada ta</h3>
          <p>Îți răspundem în aceeași zi cu un preț exact, fără angajament.</p>
          <a href="/contact" class="btn-primary btn-full">Cere ofertă gratuită</a>
          <a href="tel:+40700000000" class="btn-secondary btn-full mt-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Sună direct
          </a>
        </div>
        <div class="sidebar-links mt-md">
          <h3>Alte servicii</h3>
          <ul role="list">
            <li><a href="/servicii/vie">→ Tratamente vie</a></li>
            <li><a href="/servicii/cereale">→ Tratamente cereale</a></li>
            <li><a href="/preturi">→ Toate prețurile</a></li>
            <li><a href="/zone">→ Zone acoperite</a></li>
          </ul>
        </div>
        <div class="sidebar-trust mt-md">
          <div class="trust-point"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg> Plată după execuție</div>
          <div class="trust-point"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg> Raport GPS inclus</div>
          <div class="trust-point"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg> Anulare fără costuri</div>
        </div>
      </aside>
    </div>
  </div>

  <CtaBand />
</BaseLayout>

<style>
  .service-hero {
    position: relative;
    background-size: cover;
    background-position: center;
    padding-block: var(--space-2xl) var(--space-3xl);
    min-height: 480px;
    display: flex;
    align-items: flex-end;
    background-color: var(--color-primary-dark);
  }

  .service-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(31, 36, 24, 0.3) 0%,
      rgba(31, 36, 24, 0.75) 100%
    );
  }

  .service-hero-content {
    position: relative;
    z-index: 1;
  }

  .breadcrumb--light a,
  .breadcrumb--light { color: rgba(247,243,234,0.6); }
  .breadcrumb--light .breadcrumb-sep { color: rgba(247,243,234,0.3); }

  .eyebrow--light { color: var(--color-accent-light); }
  .eyebrow--light::before { background: var(--color-accent-light); }

  .service-hero h1 {
    color: var(--color-text-inverse);
    font-size: var(--fs-h1);
    margin-bottom: var(--space-md);
  }

  .service-hero-lead {
    color: rgba(247,243,234,0.75);
    font-size: var(--fs-body-lg);
    max-width: 560px;
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .page-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }
  @media (min-width: 960px) {
    .page-grid { grid-template-columns: 1fr 300px; }
  }

  .treatment-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: var(--space-md) 0;
  }

  .treatment-item {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .treatment-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: var(--color-primary-soft);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    margin-top: 2px;
  }

  .treatment-item h3 { font-size: var(--fs-body); font-family: var(--font-sans); font-weight: 700; margin-bottom: 4px; }
  .treatment-item p { color: var(--color-text-muted); font-size: var(--fs-small); margin: 0; line-height: var(--lh-relaxed); }

  .benefit-blocks {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
  @media (min-width: 640px) { .benefit-blocks { grid-template-columns: repeat(2, 1fr); } }

  .benefit-block {
    padding: var(--space-md);
    background: var(--color-bg-deep);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .benefit-block h3 { font-size: var(--fs-body); font-family: var(--font-sans); font-weight: 700; margin-bottom: 6px; color: var(--color-primary-dark); }
  .benefit-block p { color: var(--color-text-muted); font-size: var(--fs-small); margin: 0; line-height: var(--lh-relaxed); }

  .calendar-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }
  .calendar-box h2 { margin-bottom: var(--space-md); }

  .calendar-grid { display: flex; flex-direction: column; gap: 2px; }

  .cal-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    gap: var(--space-sm);
  }
  .cal-item:nth-child(odd) { background: var(--color-bg-deep); }
  .cal-period { font-weight: 700; font-size: var(--fs-small); flex-shrink: 0; min-width: 130px; }
  .cal-desc { font-size: var(--fs-small); color: var(--color-text-muted); }

  .price-section h2 { margin-bottom: var(--space-md); }

  .price-table-simple {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--fs-small);
  }
  .price-row:last-child { border-bottom: none; }
  .price-row--note { background: var(--color-accent-soft); color: var(--color-accent-dark); }

  .price-val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
  }
  .price-row--note .price-val { color: var(--color-accent-dark); }

  .sidebar-cta {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    border-top: 4px solid var(--color-primary);
    position: sticky;
    top: 84px;
  }
  .sidebar-cta h3 { margin-bottom: var(--space-xs); }
  .sidebar-cta p { color: var(--color-text-muted); font-size: var(--fs-small); margin-bottom: var(--space-md); line-height: var(--lh-relaxed); }

  .sidebar-links {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
  }
  .sidebar-links h3 { font-size: var(--fs-small); font-family: var(--font-sans); text-transform: uppercase; letter-spacing: var(--tracking-wider); color: var(--color-text-muted); margin-bottom: var(--space-sm); }
  .sidebar-links ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .sidebar-links a { color: var(--color-text-muted); text-decoration: none; font-size: var(--fs-small); font-weight: 500; transition: color var(--duration-fast) var(--ease); }
  .sidebar-links a:hover { color: var(--color-primary); }

  .sidebar-trust { display: flex; flex-direction: column; gap: 8px; }
  .trust-point {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .trust-point svg { color: var(--color-primary); flex-shrink: 0; }

  .img-frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-primary-soft);
  }
  .img-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .aspect-16-9 { aspect-ratio: 16 / 9; }
</style>
