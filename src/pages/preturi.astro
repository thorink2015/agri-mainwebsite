---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "PriceSpecification",
  "name": "Prețuri pulverizare cu drona",
  "description": "Prețuri pentru tratamente cu drona în România și Moldova. De la 20 €/ha pentru cereale, 24 €/ha pentru livezi, 25 €/ha pentru vie.",
  "priceCurrency": "EUR"
};
---

<BaseLayout
  title="Prețuri tratamente cu drona · De la 20 €/ha · Hectar"
  description="Prețuri clare și corecte pentru pulverizare cu drona în România și Moldova. De la 20 €/ha pentru cereale, 24 €/ha livezi, 25 €/ha vie. Fără costuri ascunse."
  canonical="/preturi"
  schema={schema}
>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">Transparent și cinstit</span>
      <h1>Prețuri clare, fără surprize</h1>
      <p class="lead">Știi prețul înainte să venim. Știi exact ce e inclus. Plătești după ce vezi cu ochii tăi că tratamentul s-a terminat.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="price-header">
        <span class="eyebrow">Tarife pe hectar</span>
        <h2>Tabel de prețuri</h2>
        <p class="text-muted">Prețuri orientative confirmate după discuție. TVA inclus pentru persoane fizice.</p>
      </div>

      <div class="table-wrap mt-lg">
        <table class="price-table">
          <thead>
            <tr>
              <th>Cultură</th>
              <th>1 – 10 ha</th>
              <th>10 – 50 ha</th>
              <th>Peste 50 ha</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <div class="crop-cell">
                  <span class="crop-name">Cereale</span>
                  <span class="crop-sub">grâu, orz, rapiță, triticale</span>
                </div>
              </td>
              <td><strong>30 €/ha</strong></td>
              <td><strong>25 €/ha</strong></td>
              <td><strong class="price-best">20 €/ha</strong></td>
            </tr>
            <tr>
              <td>
                <div class="crop-cell">
                  <span class="crop-name">Culturi tehnice</span>
                  <span class="crop-sub">porumb, floarea-soarelui, soia, sfeclă</span>
                </div>
              </td>
              <td><strong>30 €/ha</strong></td>
              <td><strong>25 €/ha</strong></td>
              <td><strong class="price-best">20 €/ha</strong></td>
            </tr>
            <tr>
              <td>
                <div class="crop-cell">
                  <span class="crop-name">Livezi</span>
                  <span class="crop-sub">meri, peri, pruni, cireși, caiși, nuci</span>
                </div>
              </td>
              <td><strong>32 €/ha</strong></td>
              <td><strong>28 €/ha</strong></td>
              <td><strong class="price-best">24 €/ha</strong></td>
            </tr>
            <tr>
              <td>
                <div class="crop-cell">
                  <span class="crop-name">Vie</span>
                  <span class="crop-sub">vie de masă, vie de vin, podgorii</span>
                </div>
              </td>
              <td><strong>35 €/ha</strong></td>
              <td><strong>30 €/ha</strong></td>
              <td><strong class="price-best">25 €/ha</strong></td>
            </tr>
            <tr class="row-extra">
              <td>
                <div class="crop-cell">
                  <span class="crop-name">Tratamente de noapte</span>
                  <span class="crop-sub">la cerere, albinele protejate</span>
                </div>
              </td>
              <td colspan="3" class="extra-note">+ 3 €/ha față de tariful de zi</td>
            </tr>
            <tr class="row-extra">
              <td>
                <div class="crop-cell">
                  <span class="crop-name">Urgențe (sub 48h)</span>
                  <span class="crop-sub">disponibil în limita programului</span>
                </div>
              </td>
              <td colspan="3" class="extra-note">+ 20% față de tariful standard</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="table-note">* Dacă ai deja soluția de tratament cumpărată, prețul scade cu 3–5 €/ha. Spune-ne asta la cererea de ofertă.</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2" style="gap: var(--space-xl); align-items: start;">
        <div class="included-box">
          <h2>Ce e inclus în preț</h2>
          <ul class="check-list mt-md">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              <span>Deplasare până la 100 km (dus)</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              <span>Operatorul calificat cu licență AACR</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              <span>Bateriile și încărcarea lor pe teren</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              <span>Apa necesară amestecului</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              <span>Raport GPS cu suprafața tratată, ora și condițiile meteo</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              <span>Asigurare RC pe toată durata zborului</span>
            </li>
          </ul>
        </div>

        <div>
          <div class="notincluded-box">
            <h2>Ce nu e inclus</h2>
            <div class="ni-item mt-md">
              <h3>Soluția de tratament</h3>
              <p>O poți aduce tu, sau o aducem noi la prețul de achiziție plus un mic adaos transparent. Niciodată nu te forțăm să cumperi de la noi.</p>
            </div>
            <div class="ni-item">
              <h3>Deplasare peste 100 km</h3>
              <p>Adăugăm 0,80 €/km peste 100 km (distanța dus). Costul exact îl știi din ofertă — înainte să accepți.</p>
            </div>
            <div class="ni-item">
              <h3>Suprafețe sub 0,5 ha</h3>
              <p>Există un tarif minim de 30 € per intervenție, indiferent de suprafață. Se discută de la caz la caz pentru parcele mici.</p>
            </div>
          </div>

          <div class="payment-box mt-md">
            <h2>Cum plătești</h2>
            <div class="payment-options mt-md">
              <div class="payment-opt">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                <span>Transfer bancar</span>
              </div>
              <div class="payment-opt">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h4"/><circle cx="16" cy="12" r="1"/></svg>
                <span>Numerar cu bon fiscal</span>
              </div>
              <div class="payment-opt">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <span>Factură cu scadență 14 zile</span>
              </div>
            </div>
            <p class="mt-sm text-small text-muted">Plata se face după terminarea tratamentului. Nu cererem avans.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="faq-prices">
        <span class="eyebrow">Întrebări frecvente</span>
        <h2>Despre prețuri și factură</h2>
        <div class="faq-list mt-lg">
          <div class="faq-item">
            <h3>Cum se calculează suprafața?</h3>
            <p>Folosim traseul GPS înregistrat de dronă. Suprafața o calculăm noi, înainte de tratament pe harta cadastrală, și o confirmăm cu tine. Nu există surprize.</p>
          </div>
          <div class="faq-item">
            <h3>Pot cere factură pe firmă?</h3>
            <p>Da. Emitem factură pe firmă sau pe persoană fizică autorizată. TVA-ul se adaugă pentru facturile B2B. Menționează la comandă.</p>
          </div>
          <div class="faq-item">
            <h3>Ce se întâmplă dacă plouă și tratamentul se anulează?</h3>
            <p>Anulăm fără costuri dacă condițiile nu permit zborul. Reprogramăm în prima zi disponibilă fără taxă suplimentară.</p>
          </div>
          <div class="faq-item">
            <h3>Prețul include soluția de tratament?</h3>
            <p>Nu. Prețurile de mai sus acoperă zborul și serviciul. Soluția e separată — o aduci tu sau o furnizăm noi la prețul de achiziție plus adaos mic transparent.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Cere ofertă exactă pentru parcela ta"
    subtext="Spune-ne cultura, suprafața și zona — îți trimitem prețul final în aceeași zi."
    primaryLabel="Cere ofertă acum"
    primaryHref="/contact"
    secondaryLabel="0700 000 000"
    secondaryHref="tel:+40700000000"
  />
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-bg-dark);
    padding-block: var(--space-xl) var(--space-2xl);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .page-hero .eyebrow { color: var(--color-accent-light); }
  .page-hero .eyebrow::before { background: var(--color-accent-light); }
  .page-hero h1 { font-size: var(--fs-h1); color: var(--color-text-inverse); margin-bottom: var(--space-md); }
  .page-hero .lead { color: rgba(247,243,234,0.65); max-width: 520px; margin: 0; }

  .price-header { text-align: center; max-width: 520px; margin-inline: auto; }
  .price-header p { margin-top: var(--space-xs); }

  .price-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .price-table thead tr {
    background: var(--color-primary-dark);
  }

  .price-table thead th {
    color: var(--color-text-inverse);
    font-size: var(--fs-small);
    font-weight: 600;
    text-align: left;
    padding: 14px 20px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .price-table thead th:first-child { width: 40%; }

  .price-table tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background var(--duration-fast) var(--ease);
  }
  .price-table tbody tr:hover { background: var(--color-bg-deep); }
  .price-table tbody tr:last-child { border-bottom: none; }

  .price-table tbody td {
    padding: 16px 20px;
    font-size: var(--fs-small);
    vertical-align: middle;
  }

  .crop-cell { display: flex; flex-direction: column; gap: 2px; }
  .crop-name { font-weight: 600; color: var(--color-text-strong); }
  .crop-sub { font-size: var(--fs-xs); color: var(--color-text-muted); }

  .price-best { color: var(--color-primary); font-size: 1.05rem; }

  .row-extra td { background: var(--color-accent-soft); }
  .extra-note { color: var(--color-accent-dark); font-weight: 600; text-align: center; }

  .table-note {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    font-style: italic;
  }

  /* Included box */
  .included-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    border-top: 4px solid var(--color-primary);
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .check-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: var(--fs-small);
    color: var(--color-text);
  }

  .check-list li svg {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Not included */
  .notincluded-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    border-left: 4px solid var(--color-accent);
  }

  .ni-item {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .ni-item:last-child { border-bottom: none; }
  .ni-item h3 { font-size: var(--fs-body); font-family: var(--font-sans); font-weight: 700; margin-bottom: 4px; }
  .ni-item p { font-size: var(--fs-small); color: var(--color-text-muted); margin: 0; line-height: var(--lh-relaxed); }

  /* Payment */
  .payment-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .payment-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  @media (min-width: 480px) {
    .payment-options { flex-direction: row; flex-wrap: wrap; }
  }

  .payment-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--color-text);
    flex: 1;
    min-width: 140px;
  }
  .payment-opt svg { color: var(--color-primary); flex-shrink: 0; }

  /* FAQ */
  .faq-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
  @media (min-width: 640px) { .faq-list { grid-template-columns: repeat(2, 1fr); } }

  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-lg);
  }

  .faq-item h3 { font-size: var(--fs-body); font-family: var(--font-sans); font-weight: 700; margin-bottom: var(--space-xs); }
  .faq-item p { font-size: var(--fs-small); color: var(--color-text-muted); margin: 0; line-height: var(--lh-relaxed); }
</style>
