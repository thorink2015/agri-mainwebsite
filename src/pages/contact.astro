---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact · Programează un tratament cu drona · Hectar"
  description="Sună, scrie sau completează formularul. Răspundem în aceeași zi. Tratamente cu drona în România și Moldova."
  canonical="/contact"
>
  <div class="container section">
    <h1>Contact</h1>
    <p class="lead mt-sm">Poți să ne scrii în trei feluri. Alege-l pe cel mai simplu pentru tine.</p>

    <div class="contact-grid mt-xl">
      <div class="contact-channels">
        <div class="channel">
          <div class="channel-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h2>Sună direct</h2>
            <a href="tel:+40700000000" class="channel-number">0700 000 000</a>
            <p class="text-muted text-small mt-sm">De luni până sâmbătă, între 07:00 și 21:00.</p>
          </div>
        </div>

        <div class="channel">
          <div class="channel-icon channel-icon-whatsapp" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <div>
            <h2>WhatsApp</h2>
            <a href="https://wa.me/40700000000" class="channel-number" target="_blank" rel="noopener">0700 000 000</a>
            <p class="text-muted text-small mt-sm">Poți trimite și poze cu câmpul sau cu problema.</p>
          </div>
        </div>

        <div class="channel">
          <div class="channel-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div>
            <h2>Email</h2>
            <a href="mailto:contact@hectar.ro" class="channel-number">contact@hectar.ro</a>
          </div>
        </div>
      </div>

      <div class="contact-form-section">
        <h2>Sau completează formularul</h2>
        <p class="text-muted text-small mt-sm mb-lg">Completează câmpurile de mai jos și îți răspundem în aceeași zi, de obicei în câteva ore.</p>
        <ContactForm />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 960px) {
    .contact-grid {
      grid-template-columns: 300px 1fr;
      align-items: start;
    }
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .channel {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .channel-icon {
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .channel h2 {
    font-size: var(--fs-h3);
    margin-bottom: 4px;
  }

  .channel-number {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-serif);
  }

  .channel-number:hover {
    color: var(--color-primary);
  }

  .contact-form-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .contact-form-section h2 {
    margin-bottom: 0;
  }

  .mb-lg { margin-bottom: var(--space-lg); }
</style>
