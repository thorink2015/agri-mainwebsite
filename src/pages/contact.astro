---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact · Programează tratament cu drona · Hectar"
  description="Sună, scrie pe WhatsApp sau completează formularul. Răspundem în aceeași zi. Programare tratamente cu drona în România și Moldova."
  canonical="/contact"
>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">Hai să vorbim</span>
      <h1>Contactează-ne</h1>
      <p class="lead">Răspundem în aceeași zi — de obicei în câteva ore. Spune-ne cultura, suprafața și zona, și îți trimitem un preț imediat.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <div class="contact-left">
          <div class="channels">
            <a href="tel:+40700000000" class="channel-card">
              <div class="channel-icon channel-icon--phone">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div class="channel-body">
                <span class="channel-label">Telefon</span>
                <span class="channel-value">0700 000 000</span>
                <span class="channel-note">Lun–Sâm · 07:00–21:00</span>
              </div>
              <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <a href="https://wa.me/40700000000" class="channel-card" target="_blank" rel="noopener">
              <div class="channel-icon channel-icon--whatsapp">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </div>
              <div class="channel-body">
                <span class="channel-label">WhatsApp</span>
                <span class="channel-value">0700 000 000</span>
                <span class="channel-note">Poți trimite și poze cu câmpul</span>
              </div>
              <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <a href="mailto:contact@hectar.ro" class="channel-card">
              <div class="channel-icon channel-icon--email">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div class="channel-body">
                <span class="channel-label">Email</span>
                <span class="channel-value">contact@hectar.ro</span>
                <span class="channel-note">Răspundem în aceeași zi</span>
              </div>
              <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <div class="info-card mt-lg">
            <h3>Ce să pregătești</h3>
            <p>Ca să îți dăm un preț rapid și exact, ajută dacă știi:</p>
            <ul class="info-list mt-sm">
              <li>Tipul culturii și faza de vegetație</li>
              <li>Suprafața aproximativă (în hectare)</li>
              <li>Județul sau localitatea</li>
              <li>Ce problemă ai (boală, dăunător, nutriție)</li>
            </ul>
            <p class="mt-sm text-small text-muted">Dacă nu știi exact, nu e nicio problemă — te ajutăm noi să identificăm.</p>
          </div>

          <div class="schedule-card mt-md">
            <div class="schedule-dot" aria-hidden="true"></div>
            <div>
              <strong>Program</strong>
              <p>Luni – Sâmbătă: 07:00 – 21:00</p>
              <p class="text-muted text-small">În sezon de vârf, răspundem și duminica la urgențe.</p>
            </div>
          </div>
        </div>

        <div class="contact-right">
          <div class="form-card">
            <h2>Trimite-ne un mesaj</h2>
            <p class="text-muted text-small mt-xs mb-lg">Completează formularul și îți răspundem în aceeași zi, de obicei în câteva ore.</p>
            <ContactForm />
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-bg-dark);
    padding-block: var(--space-xl) var(--space-2xl);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .page-hero .eyebrow { color: var(--color-accent-light); }
  .page-hero .eyebrow::before { background: var(--color-accent-light); }
  .page-hero h1 { font-size: var(--fs-h1); color: var(--color-text-inverse); margin-bottom: var(--space-md); }
  .page-hero .lead { color: rgba(247,243,234,0.65); max-width: 520px; margin: 0; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }
  @media (min-width: 960px) {
    .contact-grid { grid-template-columns: 360px 1fr; }
  }

  /* Channels */
  .channels { display: flex; flex-direction: column; gap: var(--space-sm); }

  .channel-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--duration-fast) var(--ease), border-color var(--duration-fast) var(--ease), transform var(--duration-fast) var(--ease);
  }
  .channel-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
    color: var(--color-text);
  }

  .channel-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #fff;
  }
  .channel-icon--phone { background: var(--color-primary); }
  .channel-icon--whatsapp { background: #25D366; }
  .channel-icon--email { background: var(--color-accent); }

  .channel-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .channel-label { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--color-text-muted); font-weight: 600; }
  .channel-value { font-size: var(--fs-body); font-weight: 700; color: var(--color-text-strong); }
  .channel-note { font-size: var(--fs-xs); color: var(--color-text-muted); }
  .channel-arrow { color: var(--color-text-muted); flex-shrink: 0; }

  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    border-left: 4px solid var(--color-primary);
  }
  .info-card h3 { font-size: var(--fs-body-lg); margin-bottom: var(--space-xs); }
  .info-card p { font-size: var(--fs-small); color: var(--color-text-muted); margin: 0; line-height: var(--lh-relaxed); }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .info-list li {
    font-size: var(--fs-small);
    color: var(--color-text);
    padding-left: 16px;
    position: relative;
  }
  .info-list li::before {
    content: "·";
    position: absolute;
    left: 4px;
    color: var(--color-primary);
    font-weight: 700;
  }

  .schedule-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-lg);
  }
  .schedule-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-success);
    flex-shrink: 0;
    margin-top: 4px;
    box-shadow: 0 0 0 3px rgba(90, 122, 74, 0.2);
    animation: pulse-dot 2s infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 3px rgba(90, 122, 74, 0.2); }
    50% { box-shadow: 0 0 0 6px rgba(90, 122, 74, 0.1); }
  }
  .schedule-card strong { font-size: var(--fs-small); font-weight: 700; display: block; margin-bottom: 2px; }
  .schedule-card p { font-size: var(--fs-small); margin: 0; line-height: var(--lh-relaxed); }

  /* Form */
  .form-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    box-shadow: var(--shadow-md);
  }
  .form-card h2 { margin-bottom: 0; }
  .mb-lg { margin-bottom: var(--space-lg); }

  @media (prefers-reduced-motion: reduce) {
    .schedule-dot { animation: none; }
  }
</style>
