---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Load all published (non-draft) posts
// Placeholder: posts will be loaded from content/jurnal when they exist
const publishedPosts: { slug: string; data: { title: string; date: string; excerpt: string } }[] = [];
---

<BaseLayout
  title="Jurnal de teren · Hectar"
  description="Poveștile din spatele fiecărui tratament. Ce învățăm pe câmp, ce funcționează și ce nu, cum ne pregătim pentru fiecare sezon."
  canonical="/jurnal"
>
  <div class="container section">
    <div class="text-column">
      <h1>Jurnal de teren</h1>
      <p class="lead mt-sm">Aici scriem despre ce învățăm pe câmp. Fără filtre, fără marketing. Ce a mers bine, ce a mers prost, ce am schimbat pentru data viitoare. Dacă vrei să vezi cum gândim înainte să ne angajezi, citește pe aici.</p>
    </div>

    {publishedPosts.length === 0 ? (
      <div class="empty-state mt-xl">
        <div class="empty-state-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h2>Primul articol vine curând</h2>
        <p>Suntem la început. Primul tratament, prima lecție, primul articol — toate în curând.</p>
        <p class="mt-sm">Lasă adresa de email mai jos și îți trimitem un semn când publicăm.</p>

        <form
          name="newsletter"
          method="POST"
          action="/contact/trimis"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="newsletter-form mt-md"
        >
          <input type="hidden" name="form-name" value="newsletter">
          <p aria-hidden="true" style="display:none;">
            <label>Nu completa: <input name="bot-field" tabindex="-1"></label>
          </p>
          <div class="newsletter-row">
            <label for="email-newsletter" class="sr-only">Adresa ta de email</label>
            <input
              type="email"
              id="email-newsletter"
              name="email"
              required
              placeholder="adresa@ta.ro"
              autocomplete="email"
            >
            <button type="submit" class="btn-primary">Anunță-mă</button>
          </div>
        </form>
      </div>
    ) : (
      <div class="posts-grid mt-xl">
        {publishedPosts.map(post => (
          <article class="post-card">
            <time class="post-date" datetime={post.data.date}>
              {new Date(post.data.date).toLocaleDateString('ro-RO', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="post-title"><a href={`/jurnal/${post.slug}`}>{post.data.title}</a></h2>
            <p class="post-excerpt">{post.data.excerpt}</p>
            <a href={`/jurnal/${post.slug}`} class="btn-text">Citește →</a>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .empty-state {
    text-align: center;
    max-width: 480px;
    margin-inline: auto;
    padding: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-state-icon {
    color: var(--color-primary);
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .empty-state h2 {
    margin-bottom: var(--space-xs);
  }

  .empty-state p {
    color: var(--color-text-muted);
    font-size: var(--fs-small);
    margin: 0;
  }

  .newsletter-form {
    text-align: left;
  }

  .newsletter-row {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .newsletter-row input {
    flex: 1;
    min-width: 200px;
  }

  .posts-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .posts-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .post-date {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: var(--fs-h3);
  }

  .post-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-title a:hover {
    color: var(--color-primary);
  }

  .post-excerpt {
    color: var(--color-text-muted);
    font-size: var(--fs-small);
    flex: 1;
    margin: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
