---
// Trust signals strip — credentials, certifications, guarantees
---

<div class="trust-bar">
  <div class="container">
    <ul class="trust-inner" role="list">
      <li class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        <span>Operator înregistrat AACR</span>
      </li>
      <li class="trust-divider" aria-hidden="true"></li>
      <li class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Răspuns în aceeași zi</span>
      </li>
      <li class="trust-divider" aria-hidden="true"></li>
      <li class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span>Raport GPS după fiecare zbor</span>
      </li>
      <li class="trust-divider" aria-hidden="true"></li>
      <li class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>Asigurare RC inclusă</span>
      </li>
      <li class="trust-divider" aria-hidden="true"></li>
      <li class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span>Plată după execuție</span>
      </li>
    </ul>
  </div>
</div>

<style>
  .trust-bar {
    background: var(--color-primary-soft);
    border-bottom: 1px solid var(--color-border);
    padding-block: 12px;
  }

  .trust-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--color-primary-dark);
    white-space: nowrap;
  }

  .trust-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .trust-divider {
    width: 1px;
    height: 16px;
    background: var(--color-border-strong);
    display: none;
  }

  @media (min-width: 640px) {
    .trust-divider { display: block; }
  }

  @media (max-width: 639px) {
    .trust-inner {
      justify-content: flex-start;
      gap: var(--space-sm) var(--space-md);
    }
  }
</style>
