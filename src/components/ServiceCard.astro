---
export interface Props {
  title: string;
  description: string;
  href: string;
  linkLabel?: string;
  icon?: string;
}

const { title, description, href, linkLabel = 'Detalii și preț →', icon } = Astro.props;
---

<article class="service-card">
  {icon && (
    <div class="service-card-icon" aria-hidden="true" set:html={icon} />
  )}
  <h3 class="service-card-title">{title}</h3>
  <p class="service-card-desc">{description}</p>
  <a href={href} class="btn-text service-card-link">{linkLabel}</a>
</article>

<style>
  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
  }

  .service-card-icon {
    margin-bottom: var(--space-md);
    color: var(--color-primary);
  }

  .service-card-title {
    margin-bottom: var(--space-sm);
  }

  .service-card-desc {
    color: var(--color-text-muted);
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .service-card-link {
    font-weight: 600;
    font-size: var(--fs-small);
    margin-top: auto;
  }
</style>
