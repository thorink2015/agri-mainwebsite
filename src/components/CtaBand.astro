---
export interface Props {
  heading?: string;
  subtext?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  phone?: string;
  variant?: 'dark' | 'primary' | 'accent';
}

const {
  heading = 'Ai un câmp care așteaptă tratament?',
  subtext = 'Sună acum sau lasă-ne un mesaj. Îți răspundem în aceeași zi.',
  primaryLabel = 'Programează tratament',
  primaryHref = '/contact',
  secondaryLabel,
  secondaryHref,
  phone = '0700 000 000',
  variant = 'dark',
} = Astro.props;
---

<section class:list={['cta-band', `cta-band--${variant}`]}>
  <div class="container">
    <div class="cta-band-inner">
      <div class="cta-band-text">
        <h2 class="cta-band-heading">{heading}</h2>
        <p class="cta-band-sub">{subtext}</p>
      </div>
      <div class="cta-band-actions">
        <a href={primaryHref} class="btn-primary btn-lg">{primaryLabel}</a>
        {secondaryLabel && secondaryHref && (
          <a href={secondaryHref} class="btn-ghost btn-lg">{secondaryLabel}</a>
        )}
        {phone && (
          <a href={`tel:${phone.replace(/\s/g,'')}`} class="cta-phone">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {phone}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    padding-block: var(--space-xl);
  }

  @media (min-width: 960px) {
    .cta-band { padding-block: var(--space-2xl); }
  }

  .cta-band--dark {
    background: var(--color-bg-dark);
    /* Subtle grain overlay */
    background-image:
      radial-gradient(ellipse at top right, rgba(139,111,62,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at bottom left, rgba(74,93,58,0.08) 0%, transparent 60%);
  }

  .cta-band--primary {
    background: var(--color-primary);
  }

  .cta-band--accent {
    background: var(--color-accent);
  }

  .cta-band-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  @media (min-width: 960px) {
    .cta-band-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-xl);
    }
  }

  .cta-band-text {
    flex: 1;
    max-width: 560px;
  }

  .cta-band-heading {
    font-size: var(--fs-h2);
    color: var(--color-bg);
    margin-bottom: var(--space-sm);
    line-height: var(--lh-tight);
  }

  .cta-band-sub {
    color: rgba(247, 243, 234, 0.65);
    font-size: var(--fs-body-lg);
    margin: 0;
    line-height: var(--lh-relaxed);
  }

  .cta-band-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: flex-start;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .cta-band-actions {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
    }
  }

  .cta-phone {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(247, 243, 234, 0.6);
    text-decoration: none;
    font-size: var(--fs-small);
    font-weight: 600;
    padding: 14px 0;
    transition: color var(--duration-fast) var(--ease);
  }

  .cta-phone:hover {
    color: var(--color-bg);
  }
</style>
