---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand col -->
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="Hectar — acasă">
            <svg width="36" height="36" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="32" height="32" rx="8" fill="#4A5D3A"/>
              <path d="M8 23V9h3.5v5.5h9V9H24v14h-3.5v-5.5h-9V23H8z" fill="#F7F3EA"/>
            </svg>
            <span>Hectar</span>
          </a>

          <p class="footer-tagline">
            Pulverizare aeriană cu drone profesionale pentru fermierii din România și Moldova.
          </p>

          <div class="footer-contact-block">
            <a href="tel:+40700000000" class="footer-contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              0700 000 000
            </a>
            <a href="https://wa.me/40700000000" class="footer-contact-link" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
              WhatsApp
            </a>
            <a href="mailto:contact@hectar.ro" class="footer-contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              contact@hectar.ro
            </a>
          </div>

          <div class="footer-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Operator înregistrat · Asigurare RC
          </div>
        </div>

        <!-- Servicii -->
        <div class="footer-col">
          <h3 class="footer-col-heading">Servicii</h3>
          <ul role="list" class="footer-links">
            <li><a href="/servicii/vie">Tratamente vie</a></li>
            <li><a href="/servicii/livezi">Tratamente livezi</a></li>
            <li><a href="/servicii/cereale">Tratamente cereale</a></li>
            <li><a href="/preturi">Prețuri</a></li>
            <li><a href="/zone">Zone acoperite</a></li>
          </ul>
        </div>

        <!-- Companie -->
        <div class="footer-col">
          <h3 class="footer-col-heading">Companie</h3>
          <ul role="list" class="footer-links">
            <li><a href="/despre">Despre noi</a></li>
            <li><a href="/jurnal">Jurnal de teren</a></li>
            <li><a href="/intrebari-frecvente">Întrebări frecvente</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>

        <!-- Schedule / CTA -->
        <div class="footer-col footer-cta-col">
          <h3 class="footer-col-heading">Program</h3>
          <p class="footer-schedule">
            Luni – Sâmbătă<br>
            <strong>07:00 – 21:00</strong>
          </p>
          <a href="/contact" class="btn-primary btn-full" style="margin-top: var(--space-md);">
            Programează tratament
          </a>
          <p class="footer-cta-note">Răspundem în aceeași zi</p>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copyright">© {year} Hectar · Toate drepturile rezervate.</p>
      <nav class="footer-legal-links" aria-label="Pagini legale">
        <a href="/termeni">Termeni și condiții</a>
        <span class="footer-legal-sep" aria-hidden="true">·</span>
        <a href="/confidentialitate">Confidențialitate</a>
        <span class="footer-legal-sep" aria-hidden="true">·</span>
        <a href="/cookies">Politica cookies</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 0;
  }

  .footer-top {
    background: var(--color-bg-dark);
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl) var(--space-lg);
  }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1.4fr; }
    .footer-brand { grid-column: auto; }
  }

  /* Brand */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--color-text-inverse);
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    margin-bottom: var(--space-md);
    letter-spacing: var(--tracking-tight);
  }

  .footer-logo:hover { opacity: 0.85; color: var(--color-text-inverse); }

  .footer-tagline {
    font-size: var(--fs-small);
    color: rgba(247, 243, 234, 0.75);
    line-height: var(--lh-relaxed);
    max-width: 280px;
    margin-bottom: var(--space-lg);
  }

  .footer-contact-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: var(--space-md);
  }

  .footer-contact-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(247, 243, 234, 0.85);
    text-decoration: none;
    font-size: var(--fs-small);
    transition: color var(--duration-fast) var(--ease);
  }

  .footer-contact-link:hover { color: var(--color-text-inverse); }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    background: rgba(74, 93, 58, 0.4);
    border: 1px solid rgba(134, 179, 89, 0.35);
    border-radius: var(--radius-full);
    font-size: var(--fs-xs);
    font-weight: 600;
    color: rgba(247, 243, 234, 0.85);
    letter-spacing: var(--tracking-wide);
  }

  /* Columns */
  .footer-col-heading {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: rgba(247, 243, 234, 0.6);
    margin-bottom: var(--space-md);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a {
    color: rgba(247, 243, 234, 0.8);
    text-decoration: none;
    font-size: var(--fs-small);
    transition: color var(--duration-fast) var(--ease);
  }

  .footer-links a:hover { color: var(--color-text-inverse); }

  /* CTA col */
  .footer-schedule {
    font-size: var(--fs-small);
    color: rgba(247, 243, 234, 0.75);
    line-height: var(--lh-relaxed);
    margin-bottom: 0;
  }

  .footer-schedule strong {
    color: rgba(247, 243, 234, 0.95);
  }

  .footer-cta-note {
    font-size: var(--fs-xs);
    color: rgba(247, 243, 234, 0.6);
    text-align: center;
    margin-top: var(--space-xs);
    margin-bottom: 0;
  }

  /* Bottom bar — white strip, dark readable text */
  .footer-bottom {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-sm);
  }

  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-lg);
    align-items: center;
    justify-content: space-between;
  }

  .footer-copyright {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Legal links */
  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .footer-legal-links a {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
    white-space: nowrap;
  }

  .footer-legal-links a:hover {
    color: var(--color-primary);
  }

  .footer-legal-sep {
    font-size: var(--fs-xs);
    color: var(--color-border-strong);
  }

  @media (max-width: 767px) {
    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
