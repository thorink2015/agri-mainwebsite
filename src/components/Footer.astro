---
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Col 1: Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Hectar — acasă">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="28" height="28" rx="6" fill="#4A5D3A"/>
            <path d="M7 20V8h3v5h8V8h3v12h-3v-5H10v5H7z" fill="#FAF8F3"/>
          </svg>
          <span>Hectar</span>
        </a>
        <p class="footer-tagline">Pulverizare aeriană pentru fermierii din România și Moldova.</p>
        <div class="footer-contact">
          <a href="tel:+40700000000" class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            0700 000 000
          </a>
          <a href="mailto:contact@hectar.ro" class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            contact@hectar.ro
          </a>
        </div>
      </div>

      <!-- Col 2: Services & info -->
      <div class="footer-col">
        <h3 class="footer-heading">Servicii</h3>
        <ul role="list" class="footer-links">
          <li><a href="/servicii">Toate serviciile</a></li>
          <li><a href="/servicii/vie">Tratamente vie</a></li>
          <li><a href="/servicii/livezi">Tratamente livezi</a></li>
          <li><a href="/servicii/cereale">Tratamente cereale</a></li>
          <li><a href="/preturi">Prețuri</a></li>
          <li><a href="/zone">Zone acoperite</a></li>
          <li><a href="/jurnal">Jurnal de teren</a></li>
        </ul>
      </div>

      <!-- Col 3: Company & legal -->
      <div class="footer-col">
        <h3 class="footer-heading">Companie</h3>
        <ul role="list" class="footer-links">
          <li><a href="/despre">Despre noi</a></li>
          <li><a href="/intrebari-frecvente">Întrebări frecvente</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
        <h3 class="footer-heading" style="margin-top:1.5rem;">Legal</h3>
        <ul role="list" class="footer-links">
          <li><a href="/termeni">Termeni și condiții</a></li>
          <li><a href="/confidentialitate">Confidențialitate</a></li>
          <li><a href="/cookies">Politica cookies</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© 2026 Hectar · Toate drepturile rezervate.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-text);
    color: rgba(255,255,255,0.75);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  .footer-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 960px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
    .footer-brand {
      grid-column: auto;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .footer-logo:hover {
    color: rgba(255,255,255,0.9);
  }

  .footer-tagline {
    font-size: var(--fs-small);
    margin-bottom: var(--space-md);
    color: rgba(255,255,255,0.6);
    max-width: 320px;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-contact-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: var(--fs-small);
    transition: color 150ms ease;
  }

  .footer-contact-link:hover {
    color: #fff;
  }

  .footer-heading {
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(255,255,255,0.5);
    margin-bottom: var(--space-sm);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer-links a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: var(--fs-small);
    transition: color 150ms ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    font-size: var(--fs-small);
    color: rgba(255,255,255,0.4);
  }
</style>
